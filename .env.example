# Frontend env vars (Vite). Copy this file to ".env" and fill in as needed.

# Optional: only needed if you deploy the frontend separately from the backend
# and the backend is not reachable at the default "/api" path.
# VITE_API_URL=https://your-backend-url.com/api

# Optional: if you want the browser to send form emails directly via Web3Forms
# instead of going through your backend (get a free key at web3forms.com).
# VITE_WEB3FORMS_ACCESS_KEY=

# Cashfree checkout mode used by the "Book Tele-Consult" payment flow.
# Use "sandbox" while testing, "production" once you have live Cashfree keys.
VITE_CASHFREE_MODE=sandbox
